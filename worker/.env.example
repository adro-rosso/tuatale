# Tuatale pipeline worker — environment variables.
#
# In production these are injected as Fly.io secrets (`fly secrets set ...`);
# see docs/architecture/track-b-runtime.md §4. For local dev/tests, copy this
# to worker/.env.local and fill in real values. .env.local is gitignored.
#
# For running the B.4 integration tests, point the Supabase vars at the
# tuatale-TEST project (NOT prod): use the TEST_SUPABASE_* values from
# website/.env.local mapped onto the names below.

# Supabase — the worker writes to the DB + Storage directly via the service role.
# (No NEXT_ prefix needed; the worker is not Next.js. db.js reads
#  NEXT_PUBLIC_SUPABASE_URL for parity with the website's var name.)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# Pipeline AI providers (consumed by ../src — loaded at import time).
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# Optional: Sentry for worker errors (single project shared with the website,
# distinguished by release tag). Wired up in B.5.
# SENTRY_DSN=https://xxx@sentry.io/yyy

# Inngest — only needed once the HTTP server lands in B.5. Same app/keypair as
# the website (Inngest is one app); only the served endpoint URL changes.
# INNGEST_EVENT_KEY=evt_...
# INNGEST_SIGNING_KEY=signkey-prod-...
