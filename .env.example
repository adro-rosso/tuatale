# Google AI Studio API key — get it at https://aistudio.google.com/apikey
# Copy this file to .env and fill in your real key. Never commit .env.
GEMINI_API_KEY=your_key_here

# Replicate API token — get it at https://replicate.com/account/api-tokens
# Copy this file to .env and fill in your real token. Never commit .env.
REPLICATE_API_TOKEN=your_replicate_token_here

# Anthropic Claude API key — get it at https://console.anthropic.com/settings/keys
# Copy this file to .env and fill in your real key. Never commit .env.
ANTHROPIC_API_KEY=your_anthropic_key_here
